{%- comment -%}
  Renders an inline SVG icon. Usage: {% render 'icon', name: 'star' %}
  All decorative; consumers add their own accessible labels.
{%- endcomment -%}
{%- case name -%}
  {%- when 'star' -%}
    <svg viewBox="0 0 20 20" aria-hidden="true" focusable="false"><path d="M10 1.5l2.6 5.3 5.9.9-4.3 4.1 1 5.8L10 14.9l-5.2 2.7 1-5.8L1.5 7.7l5.9-.9L10 1.5z"/></svg>
  {%- when 'leaf' -%}
    <svg viewBox="0 0 20 20" aria-hidden="true" focusable="false"><path d="M17 3C9 3 4 7 3 13c-.2 1.4 0 2.7.4 4 .1.3.5.3.6 0 .3-1 .8-2.1 1.6-3.2C7.5 16 9.9 17 12 16c4-2 5.5-8 5-13zM6.7 12.6C8.6 9.6 11.5 7.3 15 6c-2.8 1.8-5.3 4.3-7.1 7.4-.4-.2-.8-.5-1.2-.8z"/></svg>
  {%- when 'check' -%}
    <svg viewBox="0 0 20 20" aria-hidden="true" focusable="false"><path d="M8.1 15.2L3.4 10.5l1.6-1.6 3.1 3.1 7-7 1.6 1.6-8.6 8.6z"/></svg>
  {%- when 'cart' -%}
    <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path d="M4 6h2l1.2 10.4a2 2 0 002 1.6h7.9a2 2 0 002-1.7L20.4 9H7"/><circle cx="10" cy="21" r="1"/><circle cx="17" cy="21" r="1"/></svg>
  {%- when 'account' -%}
    <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false"><circle cx="12" cy="8" r="3.6"/><path d="M5 20c.8-3.5 3.6-5.4 7-5.4s6.2 1.9 7 5.4"/></svg>
  {%- when 'menu' -%}
    <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path d="M4 7h16M4 12h16M4 17h16"/></svg>
  {%- when 'close' -%}
    <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path d="M6 6l12 12M18 6L6 18"/></svg>
  {%- when 'search' -%}
    <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false"><circle cx="11" cy="11" r="6.5"/><path d="M16 16l4.5 4.5"/></svg>
{%- endcase -%}
