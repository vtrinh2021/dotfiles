<section class="vae-section vae-section--tight surface-blush">
  <div class="page-width">
    <header class="collection-header">
      <h1>Search</h1>
    </header>

    <form action="{{ routes.search_url }}" method="get" role="search" style="max-width: 560px; margin-bottom: 3rem;">
      <div class="field" style="display: flex; gap: 0.6rem; margin-bottom: 0;">
        <label for="SearchInput" style="position:absolute;clip:rect(0 0 0 0);">Search our store</label>
        <input
          id="SearchInput"
          type="search"
          name="q"
          value="{{ search.terms | escape }}"
          placeholder="Search remedies, herbs, questions&hellip;">
        <button type="submit" class="btn btn--gold">Search</button>
      </div>
    </form>

    {%- if search.performed -%}
      {%- paginate search.results by 12 -%}
        {%- if search.results_count == 0 -%}
          <p>No results for &ldquo;{{ search.terms | escape }}&rdquo;. Try a different word — or browse <a href="{{ routes.all_products_collection_url }}">all remedies</a>.</p>
        {%- else -%}
          <p style="margin-bottom: 2rem;">{{ search.results_count }} results for &ldquo;{{ search.terms | escape }}&rdquo;</p>
          <div class="product-grid">
            {%- for item in search.results -%}
              {%- if item.object_type == 'product' -%}
                {% render 'product-card', product: item %}
              {%- else -%}
                <article class="article-card">
                  <h2 style="font-size: 1.3rem;"><a href="{{ item.url }}">{{ item.title | escape }}</a></h2>
                  <p>{{ item.content | strip_html | truncate: 140 }}</p>
                </article>
              {%- endif -%}
            {%- endfor -%}
          </div>
        {%- endif -%}
        {% render 'pagination', paginate: paginate %}
      {%- endpaginate -%}
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Search",
  "settings": []
}
{% endschema %}
