<section class="vae-section surface-mulberry vae-cta" style="background: var(--vae-mulberry-deep);">
  <div class="page-width">
    <p class="vae-rule">{% render 'icon', name: 'leaf' %}</p>
    <h2>{{ section.settings.heading }}</h2>
    <p class="vae-lede">{{ section.settings.text }}</p>
    <a class="btn btn--gold" href="{{ section.settings.cta_link | default: routes.all_products_collection_url }}">
      {{- section.settings.cta_label -}}
    </a>
  </div>
</section>

{% schema %}
{
  "name": "Final CTA",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Your grandmother's herbs. Your terms."
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "One box, sixty days, zero risk. That's the whole ask."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Start with one box"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Button link"
    }
  ],
  "presets": [{ "name": "Final CTA" }]
}
{% endschema %}
