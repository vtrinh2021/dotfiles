<section class="vae-section vae-section--tight surface-blush">
  <div class="page-width util-page">
    <h1>Create account</h1>

    {%- form 'create_customer' -%}
      {%- if form.errors -%}
        <div class="form-errors">
          <p>Please correct the following:</p>
          <ul>
            {%- for field in form.errors -%}
              <li>{{ form.errors.translated_fields[field] | capitalize }} {{ form.errors.messages[field] }}</li>
            {%- endfor -%}
          </ul>
        </div>
      {%- endif -%}
      <div class="field">
        <label for="RegisterFirstName">First name</label>
        <input type="text" id="RegisterFirstName" name="customer[first_name]" autocomplete="given-name">
      </div>
      <div class="field">
        <label for="RegisterLastName">Last name</label>
        <input type="text" id="RegisterLastName" name="customer[last_name]" autocomplete="family-name">
      </div>
      <div class="field">
        <label for="RegisterEmail">Email</label>
        <input type="email" id="RegisterEmail" name="customer[email]" required autocomplete="email">
      </div>
      <div class="field">
        <label for="RegisterPassword">Password</label>
        <input type="password" id="RegisterPassword" name="customer[password]" required autocomplete="new-password">
      </div>
      <button type="submit" class="btn btn--gold">Create account</button>
      <p style="margin-top: 1.25rem;"><a href="{{ routes.account_login_url }}">Already have an account? Sign in</a></p>
    {%- endform -%}
  </div>
</section>

{% schema %}
{
  "name": "Register",
  "settings": []
}
{% endschema %}
