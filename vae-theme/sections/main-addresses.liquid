<section class="vae-section vae-section--tight surface-blush">
  <div class="page-width util-page">
    <p style="margin-bottom: 0.5rem;"><a href="{{ routes.account_url }}">&larr; Back to account</a></p>
    <h1 style="margin-bottom: 2rem;">Addresses</h1>

    <details style="margin-bottom: 2.5rem;">
      <summary class="btn btn--gold" style="display: inline-block;">Add a new address</summary>
      {%- form 'customer_address', customer.new_address -%}
        <div style="margin-top: 1.5rem;">
          <div class="field"><label for="AddrFirst">First name</label><input type="text" id="AddrFirst" name="address[first_name]" autocomplete="given-name"></div>
          <div class="field"><label for="AddrLast">Last name</label><input type="text" id="AddrLast" name="address[last_name]" autocomplete="family-name"></div>
          <div class="field"><label for="AddrLine1">Address</label><input type="text" id="AddrLine1" name="address[address1]" autocomplete="address-line1"></div>
          <div class="field"><label for="AddrLine2">Apartment, suite, etc.</label><input type="text" id="AddrLine2" name="address[address2]" autocomplete="address-line2"></div>
          <div class="field"><label for="AddrCity">City</label><input type="text" id="AddrCity" name="address[city]" autocomplete="address-level2"></div>
          <div class="field"><label for="AddrCountry">Country/region</label>
            <select id="AddrCountry" name="address[country]" data-default="{{ customer.new_address.country }}">{{ all_country_option_tags }}</select>
          </div>
          <div class="field"><label for="AddrProvince">State/province</label><input type="text" id="AddrProvince" name="address[province]" autocomplete="address-level1"></div>
          <div class="field"><label for="AddrZip">Postal code</label><input type="text" id="AddrZip" name="address[zip]" autocomplete="postal-code"></div>
          <div class="field"><label for="AddrPhone">Phone</label><input type="tel" id="AddrPhone" name="address[phone]" autocomplete="tel"></div>
          <label style="display: block; margin-bottom: 1.25rem;">
            <input type="checkbox" name="address[default]"> Set as default address
          </label>
          <button type="submit" class="btn btn--gold">Save address</button>
        </div>
      {%- endform -%}
    </details>

    {%- paginate customer.addresses by 10 -%}
      {%- for address in customer.addresses -%}
        <div style="border-top: 1.5px solid var(--vae-rose-border); padding-block: 1.5rem;">
          {%- if address == customer.default_address -%}
            <p style="font-weight: 700; color: var(--vae-green);">Default</p>
          {%- endif -%}
          <p>{{ address | format_address }}</p>
          <p style="margin-top: 0.75rem;">
            {%- form 'customer_address', address -%}
              <button type="submit" class="btn btn--outline" name="_method" value="delete" onclick="return confirm('Delete this address?')">Delete</button>
            {%- endform -%}
          </p>
        </div>
      {%- endfor -%}
      {% render 'pagination', paginate: paginate %}
    {%- endpaginate -%}
  </div>
</section>

{% schema %}
{
  "name": "Addresses",
  "settings": []
}
{% endschema %}
