<section class="vae-section surface-mulberry">
  <div class="page-width">
    <p class="vae-rule">{% render 'icon', name: 'leaf' %}</p>
    <h2>{{ section.settings.heading }}</h2>
    {%- if section.settings.text != blank -%}
      <p class="vae-lede" style="margin-top: 0.9rem;">{{ section.settings.text }}</p>
    {%- endif -%}

    <div class="bundle-grid">
      {%- for block in section.blocks -%}
        {%- liquid
          assign bundle_product = block.settings.product
        -%}
        <div class="bundle-card{% if block.settings.featured %} bundle-card--featured{% endif %}" {{ block.shopify_attributes }}>
          {%- if block.settings.featured -%}
            <span class="bundle-card__flag">{{ block.settings.flag_label | default: 'Most chosen' | escape }}</span>
          {%- endif -%}
          <h3>{{ block.settings.title | default: bundle_product.title | escape }}</h3>
          {%- if bundle_product != blank -%}
            <p>
              {{ bundle_product.price | money }}
              {%- if bundle_product.compare_at_price > bundle_product.price -%}
                <span class="bundle-card__saving"> · save {{ bundle_product.compare_at_price | minus: bundle_product.price | money }}</span>
              {%- endif -%}
            </p>
          {%- endif -%}
          <p class="bundle-card__note">{{ block.settings.note | escape }}</p>
          {%- if bundle_product != blank -%}
            <a class="btn btn--outline" href="{{ bundle_product.url }}">View this set</a>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Bundles",
  "max_blocks": 4,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Stocking up? The sets save you more."
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Intro text",
      "default": "Every remedy is complete on its own. If you already know VAÉ is for you, the multi-cycle sets bring the price per box down."
    }
  ],
  "blocks": [
    {
      "type": "bundle",
      "name": "Bundle",
      "settings": [
        { "type": "product", "id": "product", "label": "Bundle product" },
        { "type": "text", "id": "title", "label": "Title override" },
        { "type": "text", "id": "note", "label": "Note", "default": "Three cycles of coverage, one delivery." },
        { "type": "checkbox", "id": "featured", "label": "Highlight this bundle", "default": false },
        { "type": "text", "id": "flag_label", "label": "Highlight label", "default": "Most chosen" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Bundles",
      "blocks": [
        { "type": "bundle" },
        { "type": "bundle", "settings": { "featured": true } },
        { "type": "bundle" }
      ]
    }
  ]
}
{% endschema %}
