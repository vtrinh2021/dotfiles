<section class="vae-section surface-blush">
  <div class="page-width">
    <p class="vae-rule">{% render 'icon', name: 'leaf' %}</p>
    <h2>{{ section.settings.heading }}</h2>

    <div class="how-steps">
      {%- for block in section.blocks -%}
        <div class="how-step reveal" {{ block.shopify_attributes }}>
          <h3>{{ block.settings.title | escape }}</h3>
          <p>{{ block.settings.text }}</p>
        </div>
      {%- endfor -%}
    </div>

    {%- if section.settings.skeptic_note != blank -%}
      <aside class="how-skeptic">
        <p><strong>For the skeptics:</strong> {{ section.settings.skeptic_note }}</p>
      </aside>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "How it works",
  "max_blocks": 4,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "A ritual, not a routine"
    },
    {
      "type": "textarea",
      "id": "skeptic_note",
      "label": "Skeptic note",
      "default": "You don't have to believe in anything. The herbs are listed, the tradition is documented, and the 60-day guarantee means the risk stays with us — not you."
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Wear as usual" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "Use exactly like a regular pad — same comfort, same fit, nothing new to learn." }
      ]
    }
  ],
  "presets": [
    {
      "name": "How it works",
      "blocks": [
        { "type": "step" },
        {
          "type": "step",
          "settings": {
            "title": "Let the herbs work",
            "text": "Body warmth slowly releases the herbal infusion held in the pad's core over several hours."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Notice the difference",
            "text": "Most women report a felt difference within the first few cycles. If you don't, the guarantee has you covered."
          }
        }
      ]
    }
  ]
}
{% endschema %}
