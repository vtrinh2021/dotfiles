<section class="vae-section vae-section--tight surface-blush">
  <div class="page-width">
    <div class="product-layout">

      <div class="product-gallery" data-gallery>
        <div class="product-gallery__main" data-gallery-main>
          {%- liquid
            assign featured = product.selected_or_first_available_variant.featured_image | default: product.featured_image
          -%}
          {%- if featured -%}
            <img
              src="{{ featured | image_url: width: 1100 }}"
              srcset="{{ featured | image_url: width: 700 }} 700w, {{ featured | image_url: width: 1100 }} 1100w, {{ featured | image_url: width: 1600 }} 1600w"
              sizes="(min-width: 900px) 55vw, 92vw"
              alt="{{ featured.alt | default: product.title | escape }}"
              width="{{ featured.width }}"
              height="{{ featured.height }}">
          {%- else -%}
            {{ 'product-1' | placeholder_svg_tag }}
          {%- endif -%}
        </div>
        {%- if product.images.size > 1 -%}
          <div class="product-gallery__thumbs">
            {%- for image in product.images limit: 5 -%}
              <button
                type="button"
                data-gallery-thumb
                data-src="{{ image | image_url: width: 1100 }}"
                data-srcset="{{ image | image_url: width: 700 }} 700w, {{ image | image_url: width: 1100 }} 1100w"
                aria-current="{% if image == featured %}true{% else %}false{% endif %}"
                aria-label="View image {{ forloop.index }} of {{ product.images.size }}">
                <img
                  src="{{ image | image_url: width: 180 }}"
                  alt="{{ image.alt | default: product.title | escape }}"
                  width="{{ image.width }}"
                  height="{{ image.height }}"
                  loading="lazy">
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

      <div class="product-info">
        <h1>{{ product.title | escape }}</h1>

        {%- liquid
          assign current_variant = product.selected_or_first_available_variant
        -%}
        <p class="product-info__price">
          <span data-price>{{ current_variant.price | money }}</span>
          <s data-compare-price {% unless current_variant.compare_at_price > current_variant.price %}hidden{% endunless %}>
            {%- if current_variant.compare_at_price -%}{{ current_variant.compare_at_price | money }}{%- endif -%}
          </s>
        </p>

        {%- form 'product', product, data-product-form: '', data-money-format: shop.money_format -%}
          <script type="application/json" data-variants>
            {{ product.variants | json }}
          </script>

          {%- unless product.has_only_default_variant -%}
            {%- for option in product.options_with_values -%}
              <fieldset data-option-index="{{ forloop.index0 }}">
                <legend>{{ option.name | escape }}</legend>
                <div class="option-pills">
                  {%- for value in option.values -%}
                    <label>
                      <input
                        type="radio"
                        name="option-{{ forloop.parentloop.index0 }}"
                        value="{{ value | escape }}"
                        {% if option.selected_value == value %}checked{% endif %}>
                      <span>{{ value | escape }}</span>
                    </label>
                  {%- endfor -%}
                </div>
              </fieldset>
            {%- endfor -%}
          {%- endunless -%}

          <input type="hidden" name="id" value="{{ current_variant.id }}">

          <div class="qty-row">
            <label for="Quantity">Quantity</label>
            <input type="number" id="Quantity" name="quantity" value="1" min="1" inputmode="numeric">
          </div>

          <button
            type="submit"
            name="add"
            class="btn btn--gold btn--full"
            data-add-button
            data-text-add="Add to cart"
            data-text-soldout="Sold out"
            data-text-unavailable="Unavailable"
            {% unless current_variant.available %}disabled{% endunless %}>
            {%- if current_variant.available -%}Add to cart{%- else -%}Sold out{%- endif -%}
          </button>
        {%- endform -%}

        <ul class="product-trust">
          <li>{% render 'icon', name: 'check' %}<span>60-day money-back guarantee</span></li>
          <li>{% render 'icon', name: 'check' %}<span>Free tracked shipping on every order</span></li>
          <li>{% render 'icon', name: 'check' %}<span>Five named herbs — the full formula is on the box</span></li>
        </ul>

        {%- if product.description != blank -%}
          <div class="product-info__description vae-prose">
            {{ product.description }}
          </div>
        {%- endif -%}
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Product",
  "settings": []
}
{% endschema %}
