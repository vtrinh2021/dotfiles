<section class="vae-section surface-mulberry">
  <div class="page-width">
    <div class="herbs-split">
      <div class="herbs-split__media">
        {%- if section.settings.image != blank -%}
          <img
            src="{{ section.settings.image | image_url: width: 1000 }}"
            srcset="{{ section.settings.image | image_url: width: 600 }} 600w, {{ section.settings.image | image_url: width: 1000 }} 1000w"
            sizes="(min-width: 900px) 40vw, 92vw"
            alt="{{ section.settings.image.alt | default: 'Dried medicinal herbs on aged wood in warm candlelight' }}"
            width="{{ section.settings.image.width }}"
            height="{{ section.settings.image.height }}"
            loading="lazy">
        {%- else -%}
          <img
            src="{{ 'vae-placeholder-herbs.svg' | asset_url }}"
            alt="Line drawing of snow lotus and companion herbs in gold on deep mulberry"
            width="800"
            height="1000"
            loading="lazy">
        {%- endif -%}
      </div>

      <div>
        <p class="vae-rule">{% render 'icon', name: 'leaf' %}</p>
        <h2>{{ section.settings.heading }}</h2>
        <p class="vae-lede" style="margin-top: 0.9rem;">{{ section.settings.text }}</p>

        <ul class="herb-list">
          {%- for block in section.blocks -%}
            <li class="herb-item" {{ block.shopify_attributes }}>
              {% render 'icon', name: 'leaf' %}
              <div>
                <span class="herb-item__name">{{ block.settings.name | escape }}</span>
                {%- if block.settings.pinyin != blank -%}
                  <span class="herb-item__pinyin">{{ block.settings.pinyin | escape }}</span>
                {%- endif -%}
                <p class="herb-item__function">{{ block.settings.function | escape }}</p>
              </div>
            </li>
          {%- endfor -%}
        </ul>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Herbs",
  "max_blocks": 6,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Inside every pad"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Intro text",
      "default": "Five herbs, each documented in the traditional Chinese pharmacopoeia for centuries. Nothing hidden, nothing padded — this is the whole formula."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image",
      "info": "Upload the VAÉ herb macro photograph here. A botanical illustration shows until you do."
    }
  ],
  "blocks": [
    {
      "type": "herb",
      "name": "Herb",
      "settings": [
        { "type": "text", "id": "name", "label": "Name", "default": "Snow lotus" },
        { "type": "text", "id": "pinyin", "label": "Pinyin", "default": "Xue Lian Hua" },
        { "type": "text", "id": "function", "label": "Function", "default": "The centerpiece — prized in high-altitude medicine for warmth and balance." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Herbs",
      "blocks": [
        { "type": "herb" },
        {
          "type": "herb",
          "settings": {
            "name": "White angelica",
            "pinyin": "Bai Zhi",
            "function": "Traditionally used to dispel dampness and support circulation."
          }
        },
        {
          "type": "herb",
          "settings": {
            "name": "Clove",
            "pinyin": "Ding Xiang",
            "function": "Warming and gently antimicrobial, known to every apothecary tradition."
          }
        },
        {
          "type": "herb",
          "settings": {
            "name": "Rhododendron",
            "pinyin": "Man Shan Hong",
            "function": "A mountain herb long paired with snow lotus in northern formulas."
          }
        },
        {
          "type": "herb",
          "settings": {
            "name": "Dictamnus bark",
            "pinyin": "Bai Xian Pi",
            "function": "The classical companion for calming and clearing."
          }
        }
      ]
    }
  ]
}
{% endschema %}
