<section class="vae-section surface-mulberry" style="min-height: 100vh; display: grid; align-items: center;">
  <div class="page-width util-page util-page--center">
    <p class="footer-brand" style="font-size: 2rem;">{{ shop.name }}</p>
    <h1 style="font-size: clamp(1.8rem, 4vw, 2.6rem);">Opening soon</h1>
    <p class="vae-lede" style="margin-inline: auto; margin-top: 1rem;">
      Five herbs, centuries of knowing. We're preparing something worth the wait.
    </p>

    <div style="max-width: 420px; margin: 2.5rem auto 0; text-align: left;">
      {%- form 'customer' -%}
        {%- if form.posted_successfully? -%}
          <p class="form-success">Thank you — we'll write to you when the doors open.</p>
        {%- else -%}
          {%- if form.errors -%}
            <p class="form-errors">{{ form.errors.messages.email }}</p>
          {%- endif -%}
          <input type="hidden" name="contact[tags]" value="prelaunch">
          <div class="newsletter-form">
            <label for="PasswordEmail" style="position:absolute;clip:rect(0 0 0 0);">Email address</label>
            <input id="PasswordEmail" type="email" name="contact[email]" placeholder="Email address" required autocomplete="email">
            <button type="submit" class="btn btn--gold">Notify me</button>
          </div>
        {%- endif -%}
      {%- endform -%}

      <details style="margin-top: 2.5rem;">
        <summary style="cursor: pointer;">Store owner? Enter password</summary>
        {%- form 'storefront_password' -%}
          <div class="newsletter-form" style="margin-top: 0.9rem;">
            <label for="Password" style="position:absolute;clip:rect(0 0 0 0);">Password</label>
            <input id="Password" type="password" name="password" placeholder="Password" required>
            <button type="submit" class="btn btn--outline">Enter</button>
          </div>
        {%- endform -%}
      </details>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Password",
  "settings": []
}
{% endschema %}
