<section class="vae-section surface-blush">
  <div class="page-width">
    <p class="vae-rule">{% render 'icon', name: 'leaf' %}</p>
    <h2>{{ section.settings.heading }}</h2>
    {%- if section.settings.text != blank -%}
      <p class="vae-lede" style="margin-top: 0.9rem;">{{ section.settings.text }}</p>
    {%- endif -%}

    <div class="product-grid" style="margin-top: 3rem;">
      {%- liquid
        assign collection = section.settings.collection
        assign limit = section.settings.limit
      -%}
      {%- if collection != blank -%}
        {%- for product in collection.products limit: limit -%}
          {% render 'product-card', product: product %}
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..3) -%}
          <article class="product-card">
            <div class="product-card__media">{{ 'product-1' | placeholder_svg_tag }}</div>
            <h3 class="product-card__title"><a href="#">Sample product</a></h3>
            <p class="product-card__price">$0.00</p>
          </article>
        {%- endfor -%}
      {%- endif -%}
    </div>

    {%- if collection != blank and collection.products_count > limit -%}
      <p style="margin-top: 2.5rem;">
        <a class="btn btn--outline" href="{{ collection.url }}">View all {{ collection.products_count }} products</a>
      </p>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Featured products",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The remedies"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Intro text",
      "default": "Each pad is a single, complete formulation. Start with one — every order is covered by the guarantee."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "limit",
      "label": "Products shown",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 3
    }
  ],
  "presets": [{ "name": "Featured products" }]
}
{% endschema %}
