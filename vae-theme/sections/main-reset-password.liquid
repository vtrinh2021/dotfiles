<section class="vae-section vae-section--tight surface-blush">
  <div class="page-width util-page">
    <h1>Reset password</h1>
    <p style="margin-bottom: 1.75rem;">Choose a new password for your account.</p>

    {%- form 'reset_customer_password' -%}
      {%- if form.errors -%}
        <div class="form-errors">
          <ul>
            {%- for field in form.errors -%}
              <li>{{ form.errors.translated_fields[field] | capitalize }} {{ form.errors.messages[field] }}</li>
            {%- endfor -%}
          </ul>
        </div>
      {%- endif -%}
      <div class="field">
        <label for="ResetPassword">New password</label>
        <input type="password" id="ResetPassword" name="customer[password]" required autocomplete="new-password">
      </div>
      <div class="field">
        <label for="ResetPasswordConfirm">Confirm new password</label>
        <input type="password" id="ResetPasswordConfirm" name="customer[password_confirmation]" required autocomplete="new-password">
      </div>
      <button type="submit" class="btn btn--gold">Reset password</button>
    {%- endform -%}
  </div>
</section>

{% schema %}
{
  "name": "Reset password",
  "settings": []
}
{% endschema %}
